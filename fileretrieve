(async function (page, reqElement, xpathval, testdata, timeoutsec) {
 
    const { Client } = require('ssh2');
    const fs = require('fs');
    const path = require('path');
 
    let errorCode;
 
    const outputFolderPath = path.resolve(".") + "\acquiringFiles";
 
    if (!fs.existsSync(outputFolderPath)) {
        fs.mkdirSync(outputFolderPath, { recursive: true });
    }
 
    const epochTime = new Date().getTime();
 
    // Remote file path should be passed in testdata
    const remoteFilePath = testdata;
 
    const localFileName = path.basename(remoteFilePath);
 
    const localFilePath = path.join(
        outputFolderPath,
        ${epochTime}_${localFileName}
    );
 
    const config = {
        host: "",
        port: "",
        username: "",
        password: ""
    };
 
    const downloadFile = async () => {
 
        const conn = new Client();
 
        return new Promise((resolve, reject) => {
 
            conn.on("ready", () => {
 
                console.log("SSH Connected");
 
                conn.sftp((err, sftp) => {
 
                    if (err) {
                        reject(err);
                        return;
                    }
 
                    sftp.fastGet(remoteFilePath, localFilePath, {}, (err) => {
 
                        if (err) {
                            reject(err);
                            return;
                        }
 
                        console.log("File downloaded successfully.");
 
                        conn.end();
 
                        resolve();
 
                    });
 
                });
 
            });
 
            conn.on("error", reject);
 
            conn.connect(config);
 
        });
 
    };
 
    try {
 
        await downloadFile();
 
        global.retvalue = localFilePath;
 
        return "Success. File downloaded successfully to : " + localFilePath;
 
    } catch (err) {
 
        errorCode = err;
 
        return "Failure. File download failed : " + errorCode;
 
    }
 
});
