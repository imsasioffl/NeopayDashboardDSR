(async function (page, reqElement, xpathval, testdata, timeoutsec) {

    const { Client } = require("ssh2");
    const fs = require("fs");
    const path = require("path");

    const conn = new Client();

    // Local folder
    const outputFolder = path.join(path.resolve("."), "acquiringFiles");

    if (!fs.existsSync(outputFolder)) {
        fs.mkdirSync(outputFolder, { recursive: true });
    }

    // Remote directory
    const remoteDirectory = testdata.trim();

    // SFTP Configuration
    const config = {
        host: "",
        port: "",
        username: "",
        password: ""
    };

    // Cache
    global.fileCache = {};
    global.fileList = [];

    try {

        await new Promise((resolve, reject) => {

            conn.on("ready", () => {

                conn.sftp((err, sftp) => {

                    if (err)
                        return reject(err);

                    sftp.readdir(remoteDirectory, async (err, list) => {

                        if (err)
                            return reject(err);

                        if (!list || list.length === 0) {
                            conn.end();
                            return resolve();
                        }

                        // Download sequentially
                        for (const file of list) {

                            // Skip directories
                            if (file.longname.startsWith("d"))
                                continue;

                            const remoteFile =
                                path.posix.join(remoteDirectory, file.filename);

                            const localFile =
                                path.join(
                                    outputFolder,
                                    Date.now() + "_" + file.filename
                                );

                            await new Promise((res, rej) => {

                                sftp.fastGet(
                                    remoteFile,
                                    localFile,
                                    {},
                                    function (err) {

                                        if (err)
                                            return rej(err);

                                        res();

                                    });

                            });

                            // Store path
                            global.fileList.push(localFile);

                            // Read once and cache
                            global.fileCache[localFile] =
                                fs.readFileSync(localFile, "utf8");

                        }

                        conn.end();

                        resolve();

                    });

                });

            });

            conn.on("error", reject);

            conn.connect(config);

        });

        global.retvalue = global.fileList.join("||");

        return (
            "SUCCESS\n\n" +
            "Total Files Downloaded : " +
            global.fileList.length
        );

    }
    catch (err) {

        try {
            conn.end();
        }
        catch (e) { }

        return "FAILED\n" + err;

    }

});
