(async function (page, reqElement, xpathval, testdata, timeoutsec) {

    try {

        // Check cache
        if (!global.fileCache || Object.keys(global.fileCache).length === 0) {

            return "FAILED - No cached files found. Execute RetrieveAllFiles first.";

        }

        const verifyValues = testdata
            .split("||")
            .map(v => v.trim())
            .filter(v => v !== "");

        if (verifyValues.length === 0) {

            return "FAILED - No verification values provided.";

        }

        // Search every cached file
        for (const filePath of Object.keys(global.fileCache)) {

            const content = global.fileCache[filePath];

            const lines = content.split(/\r?\n/);

            for (let i = 0; i < lines.length; i++) {

                const line = lines[i];

                if (!line.trim())
                    continue;

                // CSV Columns
                const columns = line
                    .split(",")
                    .map(col => col.trim());

                // Check all verify values exist in same line
                const matched = verifyValues.every(value =>
                    columns.includes(value)
                );

                if (matched) {

                    global.retvalue =
                        filePath +
                        "||" +
                        (i + 1) +
                        "||" +
                        line;

                    return (
                        "SUCCESS\n\n" +
                        "File : " + filePath + "\n" +
                        "Line : " + (i + 1) + "\n" +
                        "Data : " + line
                    );

                }

            }

        }

        return "FAILED - No matching data found.";

    }
    catch (err) {

        return "FAILED\n" + err;

    }

});
