(async function (page, reqElement, xpathval, testdata, timeoutsec) {

    const fs = require("fs");
    const path = require("path");

    try {

        const parts = testdata.split("||");

        if (parts.length < 2) {
            return "Invalid input. Expected format: DirectoryPath||VerifyValue1[||VerifyValue2...]";
        }

        const dirPath = parts[0].trim();
        const verifyValues = parts.slice(1).map(v => v.trim());

        if (!fs.existsSync(dirPath)) {
            return "FAILED - Directory not found: " + dirPath;
        }

        const stat = fs.statSync(dirPath);

        if (!stat.isDirectory()) {
            return "FAILED - Given path is not a directory.";
        }

        const files = fs.readdirSync(dirPath);

        if (files.length === 0) {
            return "FAILED - Directory is empty.";
        }

        for (const file of files) {

            const filePath = path.join(dirPath, file);

            // Skip folders
            if (!fs.statSync(filePath).isFile()) {
                continue;
            }

            const fileContent = fs.readFileSync(filePath, "utf8");
            const lines = fileContent.split(/\r?\n/);

            for (let i = 0; i < lines.length; i++) {

                const line = lines[i];

                if (!line.trim()) continue;

                const columns = line.split(",").map(col => col.trim());

                if (!columns.includes(verifyValues[0])) {
                    continue;
                }

                const allMatched = verifyValues.every(value =>
                    columns.includes(value)
                );

                if (allMatched) {

                    global.retvalue =
                        file +
                        "||" +
                        (i + 1) +
                        "||" +
                        line;

                    return (
                        "SUCCESS - Match found.\n" +
                        "File : " + file + "\n" +
                        "Line : " + (i + 1) + "\n" +
                        "Data : " + line
                    );
                }
            }
        }

        return "FAILED - No matching data found in any file.";

    } catch (err) {

        return "FAILED - " + err.message;

    }

});
